    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:migrate:status": "npx prisma migrate status",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "seed:centres": "npx tsx prisma/seed-centres.ts",
    "seed:centres95": "npx tsx prisma/seed-centres-95.ts",
    "seed:sessions": "npx tsx prisma/seed-sessions.ts"
