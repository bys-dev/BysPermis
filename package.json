{
  "name": "byspermis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:seed": "npx tsx prisma/seed.ts",
    "seed:demo": "npx tsx prisma/seed-demo.ts",
    "seed:auth0": "npx tsx prisma/seed-auth0.ts",
    "auth0:setup": "npx tsx scripts/setup-auth0-action.ts",
    "auth0:configure": "npx tsx scripts/configure-auth0.ts",
