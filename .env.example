# ─── Base de données ──────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/byspermis"

# ─── Auth0 (v4) ───────────────────────────────────────────
# Generate AUTH0_SECRET with: openssl rand -base64 32
AUTH0_SECRET="run: openssl rand -base64 32"
AUTH0_BASE_URL="http://localhost:3000"
AUTH0_ISSUER_BASE_URL="https://YOUR_DOMAIN.eu.auth0.com"
# AUTH0_DOMAIN is used as fallback when AUTH0_ISSUER_BASE_URL is not set
AUTH0_DOMAIN="YOUR_DOMAIN.eu.auth0.com"
AUTH0_CLIENT_ID="your_client_id"
AUTH0_CLIENT_SECRET="your_client_secret"
# Management API (pour créer / supprimer users programmatiquement, sync rôles)
AUTH0_MANAGEMENT_CLIENT_ID="your_management_client_id"
AUTH0_MANAGEMENT_CLIENT_SECRET="your_management_client_secret"

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Generated when running `stripe listen` locally, or in Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
# Commission BYS Permis : 10%
COMMISSION_RATE="0.10"

# ─── Resend (emails) ──────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="BYS Formation <noreply@bys-formation.fr>"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# APP_BASE_URL is used by server-side code (cron, email links). Falls back to NEXT_PUBLIC_APP_URL
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Stockage fichiers (documents élève/centre, logos) ────
# Prod : Clever Cloud Cellar (S3). HOST/KEY_ID/KEY_SECRET sont auto-injectés
# par l'addon Cellar. Le BUCKET n'est PAS auto-injecté : créer un bucket dans
# la console Cellar puis renseigner son nom ici (sinon fallback FS local).
CELLAR_ADDON_HOST="cellar-c2.services.clever-cloud.com"
CELLAR_ADDON_KEY_ID=""
CELLAR_ADDON_KEY_SECRET=""
CELLAR_ADDON_BUCKET="byspermis-uploads"
# Alternative Vercel Blob (si hébergé sur Vercel) : BLOB_READ_WRITE_TOKEN=""

# ─── Cron (Vercel Cron Jobs) ──────────────────────────────
# Used to authenticate Vercel cron requests via `Authorization: Bearer ${CRON_SECRET}`
# Generate with: openssl rand -hex 32
CRON_SECRET="generate: openssl rand -hex 32"

# ─── Upstash Redis (rate-limit production) ────────────────
# Optional: if not set, rate-limit falls back to in-memory (not safe in serverless).
# Create at https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Sentry (error monitoring) ────────────────────────────
# Optional: if SENTRY_DSN is not set, monitoring is disabled.
# Public DSN is exposed to the client bundle; the same DSN is fine for both.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Build-time only (sourcemap upload). Get an Auth Token from Sentry > Settings > Auth Tokens
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="byspermis"
SENTRY_PROJECT="byspermis-web"
