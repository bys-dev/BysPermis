generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  // ─── Élève ───
  ELEVE               // Apprenant / stagiaire

  // ─── Centre de formation ───
  CENTRE_OWNER        // Propriétaire du centre (Stripe, abonnement, tout)
  CENTRE_ADMIN        // Gestionnaire (formations, sessions, stats)
  CENTRE_FORMATEUR    // Moniteur / prof (ses sessions, émargement)
  CENTRE_SECRETAIRE   // Secrétariat (inscriptions, planning, sans financier)

  // ─── Plateforme BYS ───
  SUPPORT             // Agent support (tickets, modération)
  COMPTABLE           // Finance (revenus, commissions, exports)
  COMMERCIAL          // Business dev (démarchage centres, conversions)
  ADMIN               // Admin opérationnel (centres, users, paramètres)
  OWNER               // Super-admin (Sébastien — accès total)
}

enum ReservationStatus {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
  REMBOURSEE
  TERMINEE
}

enum SessionStatus {
  ACTIVE
  ANNULEE
  COMPLETE
  PASSEE
}

enum CentreStatus {
  EN_ATTENTE
  ACTIF
  SUSPENDU
}

enum TicketStatus {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

enum TicketPriorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum Modalite {
  PRESENTIEL
  DISTANCIEL
  HYBRIDE
}

enum MonetisationModel {
  ABONNEMENT
  COMMISSION
  HYBRIDE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  ANNULEE
  TRIALING
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  auth0Id       String   @unique
  email         String   @unique
  nom           String
  prenom        String
  telephone     String?
  adresse       String?
  codePostal    String?
  ville         String?
  role          Role     @default(ELEVE)
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Multi-centre: active centre selector
  activeCentreId  String?

  // Relations
  reservations    Reservation[]
  centres         Centre[]           // Si CENTRE_OWNER (peut en avoir plusieurs)
  centreMembres   CentreMembre[]     // Si formateur/admin/secrétaire d'un centre
  tickets         Ticket[]
  ticketMessages  TicketMessage[]
  notifications   Notification[]
  reviews         Review[]
  invoices        Invoice[]
  articles        Article[]
  messagesSent    Message[]          @relation("messagesSent")
  messagesReceived Message[]         @relation("messagesReceived")
  favorites       Favorite[]
  loyaltyPoints   LoyaltyPoints[]
  loyaltyLevel    String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  totalPoints     Int      @default(0)
  referralCode    String?  @unique  // Auto-generated, e.g. "BYS-JEAN42"
  referredBy      String?           // referralCode of the person who referred them

  @@map("users")
}

// ─── CENTRES DE FORMATION ────────────────────────────────

model Centre {
  id                    String             @id @default(cuid())
  nom                   String
  slug                  String             @unique
  description           String?
  logo                  String?
  adresse               String
  codePostal            String
  ville                 String
  telephone             String?
  email                 String?
  siteWeb               String?
  stripeAccountId       String?
  stripeCustomerId      String?
  stripeOnboardingDone  Boolean            @default(false)
  subscriptionStatus    SubscriptionStatus?
  subscriptionStripeId  String?
  latitude              Float?
  longitude             Float?
  profilCompletionPct   Int                @default(0)
  statut                CentreStatus       @default(EN_ATTENTE)
  isActive              Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Personnalisation
  bannerImage           String?
  couleurPrimaire       String?
  couleurSecondaire     String?
  presentationHtml      String?
  horaires              String?
  equipements           String[]
  certifications        String[]
  reseauxSociaux        Json?

  // Relations
  userId                String
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  formations            Formation[]
  membres               CentreMembre[]
  emailTemplates        EmailTemplate[]
  payments              CentrePayment[]
  invoices              Invoice[]
  promoCodes            PromoCode[]
  subscriptionPlanId    String?
  subscriptionPlan      SubscriptionPlan?  @relation(fields: [subscriptionPlanId], references: [id])

  @@map("centres")
}

// ─── MEMBRES D'UN CENTRE (formateurs, admins, secrétaires) ──

model CentreMembre {
  id        String   @id @default(cuid())
  role      Role     // CENTRE_ADMIN, CENTRE_FORMATEUR, CENTRE_SECRETAIRE
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  centreId  String
  centre    Centre   @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@unique([userId, centreId])
  @@map("centre_membres")
}

// ─── PLANS D'ABONNEMENT ──────────────────────────────────

model SubscriptionPlan {
  id              String   @id @default(cuid())
  nom             String
  stripePriceId   String   @unique
  prix            Float
  features        String[]
  maxFormations   Int
  isFeatured      Boolean  @default(false)
  commissionRate  Float
  isActive        Boolean  @default(true)
  ordre           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  centres         Centre[]

  @@map("subscription_plans")
}

// ─── FORMATIONS ──────────────────────────────────────────

model Formation {
  id            String    @id @default(cuid())
  titre         String
  slug          String    @unique
  description   String
  objectifs     String?
  programme     String?
  prerequis     String?
  publicCible   String?
  duree         String
  prix          Float
  modalite      Modalite  @default(PRESENTIEL)
  lieu          String?
  isQualiopi    Boolean   @default(false)
  isCPF         Boolean   @default(false)
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  centreId      String
  centre        Centre    @relation(fields: [centreId], references: [id], onDelete: Cascade)
  categorieId   String?
  categorie     Categorie? @relation(fields: [categorieId], references: [id])
  sessions      Session[]
  reviews       Review[]
  favorites     Favorite[]

  @@map("formations")
}

// ─── CATEGORIES ──────────────────────────────────────────

model Categorie {
  id          String      @id @default(cuid())
  nom         String      @unique
  description String?
  icon        String?
  couleur     String?
  ordre       Int         @default(0)
  formations  Formation[]

  @@map("categories")
}

// ─── SESSIONS (créneaux) ─────────────────────────────────

model Session {
  id              String        @id @default(cuid())
  dateDebut       DateTime
  dateFin         DateTime
  placesTotal     Int
  placesRestantes Int
  status          SessionStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  formationId     String
  formation       Formation     @relation(fields: [formationId], references: [id], onDelete: Cascade)
  reservations    Reservation[]

  @@map("sessions")
}

// ─── RESERVATIONS ────────────────────────────────────────

model Reservation {
  id                String            @id @default(cuid())
  numero            String            @unique @default(cuid())
  status            ReservationStatus @default(EN_ATTENTE)
  montant           Float
  commissionMontant Float?
  stripePaymentId   String?
  civilite          String?
  nom               String
  prenom            String
  email             String
  telephone         String
  adresse           String?
  codePostal        String?
  ville             String?
  numeroPermis      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  rappelEnvoye      Boolean           @default(false)

  // Relations
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  sessionId         String
  session           Session           @relation(fields: [sessionId], references: [id])
  invoice           Invoice?
  messages          Message[]

  @@map("reservations")
}

// ─── FACTURES ────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  numero        String   @unique  // FAC-2026-0001
  type          String             // "ELEVE" | "CENTRE_COMMISSION" | "CENTRE_ABONNEMENT"
  montantHT     Float
  tva           Float
  montantTTC    Float
  status        String   @default("PAYEE")  // "PAYEE" | "EN_ATTENTE" | "ANNULEE"
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  centreId      String?
  centre        Centre?  @relation(fields: [centreId], references: [id])
  reservationId String?  @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@map("invoices")
}

// ─── SUPPORT / TICKETS ───────────────────────────────────

model Ticket {
  id        String         @id @default(cuid())
  sujet     String
  status    TicketStatus   @default(OUVERT)
  priorite  TicketPriorite @default(NORMALE)
  categorie String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  messages  TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  contenu   String
  fichier   String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("ticket_messages")
}

// ─── AVIS / REVIEWS ──────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  note        Int      // 1-5 stars
  commentaire String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  formationId String
  formation   Formation @relation(fields: [formationId], references: [id])

  @@unique([userId, formationId])
  @@map("reviews")
}

// ─── FAQ ─────────────────────────────────────────────────

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  reponse   String
  categorie String?
  ordre     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── EMAIL TEMPLATES ─────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  slug        String   // "convocation", "confirmation_reservation", "rappel_session", "bienvenue", "centre_notification"
  nom         String   // "Convocation de stage", etc.
  sujet       String   // Email subject with variables like {{prenom}}, {{formation}}
  contenu     String   // HTML body with variables
  variables   String[] // List of available variables
  isActive    Boolean  @default(true)
  centreId    String?  // null = default template, centreId = centre-specific override
  centre      Centre?  @relation(fields: [centreId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, centreId])
  @@map("email_templates")
}

// ─── PAIEMENTS CENTRES ──────────────────────────────────

model CentrePayment {
  id            String   @id @default(cuid())
  type          String   // "COMMISSION" | "ABONNEMENT" | "REMBOURSEMENT"
  montant       Float
  description   String
  stripeId      String?  // Stripe payment/invoice ID
  status        String   @default("EN_ATTENTE") // "EN_ATTENTE" | "PAYE" | "ECHOUE"
  periode       String?  // "2026-03" for monthly tracking
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  centreId      String
  centre        Centre   @relation(fields: [centreId], references: [id])

  @@map("centre_payments")
}

// ─── CODES PROMO ─────────────────────────────────────────

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  type            String   // "POURCENTAGE" | "MONTANT_FIXE"
  valeur          Float    // 10 = 10% or 10€
  minAchat        Float?   // Minimum purchase amount
  maxUtilisations Int?     // Max total uses (null = unlimited)
  utilisations    Int      @default(0)
  dateDebut       DateTime
  dateFin         DateTime
  isActive        Boolean  @default(true)
  centreId        String?  // null = platform-wide, centreId = centre-specific
  centre          Centre?  @relation(fields: [centreId], references: [id])
  createdAt       DateTime @default(now())

  @@map("promo_codes")
}

// ─── PARAMETRES PLATEFORME ───────────────────────────────

model PlatformSettings {
  id                 String            @id @default("default")
  commissionRate     Float             @default(10)
  monetisationModel  MonetisationModel @default(COMMISSION)
  updatedAt          DateTime          @updatedAt

  @@map("platform_settings")
}

// ─── ARTICLES / BLOG ────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  titre       String
  slug        String    @unique
  extrait     String    // Short excerpt for cards
  contenu     String    // Full HTML content
  image       String?   // Cover image URL
  categorie   String?   // "actualites" | "conseils" | "reglementation" | "partenaires"
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  @@map("articles")
}

// ─── MESSAGERIE CENTRE-ELEVE ────────────────────────────

model Message {
  id        String   @id @default(cuid())
  contenu   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId    String
  sender      User     @relation("messagesSent", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("messagesReceived", fields: [receiverId], references: [id])

  // Context
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@map("messages")
}

// ─── PROGRAMME DE FIDÉLITÉ ──────────────────────────────

model LoyaltyPoints {
  id          String   @id @default(cuid())
  points      Int
  type        String   // "GAIN" | "DEPENSE"
  description String
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

// ─── FAVORIS / WISHLIST ─────────────────────────────────

model Favorite {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@map("favorites")
}
