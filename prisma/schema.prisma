generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  // ─── Élève ───
  ELEVE // Apprenant / stagiaire

  // ─── Centre de formation ───
  CENTRE_OWNER // Propriétaire du centre (Stripe, abonnement, tout)
  CENTRE_ADMIN // Gestionnaire (formations, sessions, stats)
  CENTRE_FORMATEUR // Moniteur / prof (ses sessions, émargement)
  CENTRE_SECRETAIRE // Secrétariat (inscriptions, planning, sans financier)

  // ─── Plateforme BYS ───
  SUPPORT // Agent support (tickets, modération)
  COMPTABLE // Finance (revenus, commissions, exports)
  COMMERCIAL // Business dev (démarchage centres, conversions)
  ADMIN // Admin opérationnel (centres, users, paramètres)
  OWNER // Super-admin (Sébastien — accès total)
}

// Fonction réglementaire d'un animateur de stage (distincte du droit d'accès `Role`).
// Chaque stage est co-animé par un expert en sécurité routière et un psychologue,
// chacun titulaire d'un numéro d'autorisation d'animer délivré par la préfecture.
enum FonctionAnimateur {
  EXPERT_SR // Expert en sécurité routière (BAFM)
  PSYCHOLOGUE // Animateur psychologue
}

enum ReservationStatus {
  EN_ATTENTE
  EN_ATTENTE_PAIEMENT // Réservation créée, en attente de validation Stripe (placeholder anti race-condition)
  CONFIRMEE
  ANNULEE
  REMBOURSEE
  TERMINEE
}

enum SessionStatus {
  ACTIVE
  ANNULEE
  COMPLETE
  PASSEE
}

enum CentreStatus {
  EN_ATTENTE
  ACTIF
  SUSPENDU
}

enum TicketStatus {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

enum TicketPriorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum Modalite {
  PRESENTIEL
  DISTANCIEL
  HYBRIDE
}

enum StageType {
  VOLONTAIRE // Récupération volontaire (max 1 / an)
  PROBATOIRE // Permis probatoire
  LETTRE_48N // Notification 48N (jeunes permis < 3 ans)
  LETTRE_48SI // Notification 48SI (solde de points épuisé)
  JUDICIAIRE // Peine alternative judiciaire
  COMPOSITION_PENALE // Composition pénale
}

enum MonetisationModel {
  ABONNEMENT
  COMMISSION
  HYBRIDE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  ANNULEE
  TRIALING
}

enum QuestionnaireType {
  CENTRE
  PLATFORM
}

// ─── DOCUMENTS (échange centre ↔ élève) ──────────────────

enum DocumentDirection {
  CENTRE_VERS_ELEVE
  ELEVE_VERS_CENTRE
}

enum DocumentKind {
  PERMIS // photo du permis (élève)
  PIECE_IDENTITE // CNI / passeport (élève)
  LETTRE_48N // lettre 48N (élève)
  EMARGEMENT // feuille d'émargement individuelle (généré par le centre)
  BON_ACCORD // bon d'accord à valeur probante (à cocher par l'élève)
  REGLEMENT // règlement intérieur / programme (centre → élève)
  // Documents transactionnels archivés (générés par la plateforme, cf. lib/documents.ts)
  CONVOCATION // convocation de stage
  FACTURE // facture élève
  ATTESTATION // attestation de suivi de stage (Annexe I)
  AUTRE
}

enum DocumentStatus {
  ENVOYE
  LU
  ACCEPTE
  REFUSE
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  auth0Id             String    @unique
  email               String    @unique
  nom                 String
  prenom              String
  telephone           String?
  adresse             String?
  codePostal          String?
  ville               String?
  role                Role      @default(ELEVE)
  isBlocked           Boolean   @default(false)
  emailVerified       Boolean   @default(false)
  isProfileComplete   Boolean   @default(false)
  dateNaissance       DateTime?
  numeroPermis        String?
  dateObtentionPermis DateTime?
  categoriesPermis    String[] // ["A", "B", "C", "D"]
  newsletterOptIn     Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Multi-centre: active centre selector
  activeCentreId String?

  // Relations
  reservations     Reservation[]
  centres          Centre[] // Si CENTRE_OWNER (peut en avoir plusieurs)
  centreMembres    CentreMembre[] // Si formateur/admin/secrétaire d'un centre
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  notifications    Notification[]
  reviews                  Review[]
  questionnaireResponses   QuestionnaireResponse[]
  uploadedDocuments        Document[]              @relation("UploadedDocuments")
  verifiedDocuments        Document[]              @relation("VerifiedDocuments")
  invoices                 Invoice[]
  emailLogs                EmailLog[]
  articles         Article[]
  messagesSent     Message[]       @relation("messagesSent")
  messagesReceived Message[]       @relation("messagesReceived")
  favorites        Favorite[]
  loyaltyPoints    LoyaltyPoints[]
  availabilities   Availability[]
  loyaltyLevel     String          @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  totalPoints      Int             @default(0)
  referralCode     String?         @unique // Auto-generated, e.g. "BYS-JEAN42"
  referredBy       String? // referralCode of the person who referred them

  @@map("users")
}

// ─── CENTRES DE FORMATION ────────────────────────────────

model Centre {
  id                   String              @id @default(cuid())
  nom                  String
  slug                 String              @unique
  description          String?
  logo                 String?
  adresse              String
  codePostal           String
  ville                String
  telephone            String?
  email                String?
  siteWeb              String?
  siret                String? // N° SIRET (utilisé pour les contrats)
  stripeAccountId      String?
  stripeCustomerId     String?
  stripeOnboardingDone Boolean             @default(false)
  subscriptionStatus   SubscriptionStatus?
  subscriptionStripeId String?
  latitude             Float?
  longitude            Float?
  profilCompletionPct  Int                 @default(0)
  statut               CentreStatus        @default(EN_ATTENTE)
  isActive             Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Personnalisation
  bannerImage       String?
  couleurPrimaire   String?
  couleurSecondaire String?
  presentationHtml  String?
  horaires          String?
  equipements       String[]
  certifications    String[]
  reseauxSociaux    Json?

  // Facturation / juridique
  raisonSociale          String?
  tva                    String? // ex "FR12345678901"
  ape                    String? // ex "8559A"
  iban                   String?
  bic                    String?
  mentionsLegales        String?
  cgv                    String?
  nomResponsable         String?
  signatureUrl           String? // URL image signature
  commissionRateOverride Float? // null = utilise COMMISSION_RATE global

  // Agrément préfectoral (obligatoire pour exercer — stages récup points)
  agrementNumber      String?
  agrementDepartement String? // ex "95"
  agrementValidUntil  DateTime?

  // Relations
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  formations         Formation[]
  membres            CentreMembre[]
  emailTemplates     EmailTemplate[]
  payments           CentrePayment[]
  invoices           Invoice[]
  promoCodes             PromoCode[]
  subscriptionPlanId     String?
  subscriptionPlan       SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  questionnaireQuestions QuestionnaireQuestion[]
  questionnaireResponses QuestionnaireResponse[]
  documents              Document[]
  documentTemplates      CentreDocumentTemplate[]
  emailLogs              EmailLog[]

  @@map("centres")
}

// ─── MEMBRES D'UN CENTRE (formateurs, admins, secrétaires) ──

model CentreMembre {
  id        String   @id @default(cuid())
  role      Role // CENTRE_ADMIN, CENTRE_FORMATEUR, CENTRE_SECRETAIRE
  // Fonction réglementaire (optionnelle) : renseignée pour les animateurs de stage.
  // Alimente l'attestation de suivi (Annexe I) avec le n° d'autorisation d'animer.
  fonctionAnimateur  FonctionAnimateur?
  numeroAutorisation String? // N° d'autorisation d'animer (préfecture)
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  centreId String
  centre   Centre @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@unique([userId, centreId])
  @@map("centre_membres")
}

// ─── PLANS D'ABONNEMENT ──────────────────────────────────

model SubscriptionPlan {
  id             String   @id @default(cuid())
  nom            String
  stripePriceId  String   @unique
  prix           Float
  features       String[]
  maxFormations  Int
  isFeatured     Boolean  @default(false)
  commissionRate Float
  isActive       Boolean  @default(true)
  ordre          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  centres Centre[]

  @@map("subscription_plans")
}

// ─── FORMATIONS ──────────────────────────────────────────

model Formation {
  id              String    @id @default(cuid())
  titre           String
  slug            String    @unique
  description     String
  objectifs       String?
  programme       String?
  prerequis       String?
  publicCible     String?
  duree           String
  prix            Float
  modalite        Modalite  @default(PRESENTIEL)
  lieu            String?
  isQualiopi      Boolean   @default(false)
  isCPF           Boolean   @default(false)
  image           String?
  isActive        Boolean   @default(true)
  // Métier — stage récupération de points
  stageType       StageType @default(VOLONTAIRE)
  pointsRecovered Int       @default(4)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  centreId    String
  centre      Centre     @relation(fields: [centreId], references: [id], onDelete: Cascade)
  categorieId String?
  categorie   Categorie? @relation(fields: [categorieId], references: [id])
  sessions    Session[]
  reviews     Review[]
  favorites   Favorite[]
  questionnaireResponses QuestionnaireResponse[]

  @@map("formations")
}

// ─── CATEGORIES ──────────────────────────────────────────

model Categorie {
  id          String      @id @default(cuid())
  nom         String      @unique
  description String?
  icon        String?
  couleur     String?
  ordre       Int         @default(0)
  formations  Formation[]

  @@map("categories")
}

// ─── SESSIONS (créneaux) ─────────────────────────────────

model Session {
  id              String        @id @default(cuid())
  dateDebut       DateTime
  dateFin         DateTime
  placesTotal     Int
  placesRestantes Int
  status          SessionStatus @default(ACTIVE)
  // Animateur responsable (texte libre) et horaires — utilisés sur la feuille d'émargement
  formateurResponsable String?
  horaires             String? // ex "9h00 – 12h30 / 13h30 – 17h00"
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  formationId  String
  formation    Formation     @relation(fields: [formationId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@map("sessions")
}

// ─── RESERVATIONS ────────────────────────────────────────

model Reservation {
  id                String            @id @default(cuid())
  numero            String            @unique @default(cuid())
  status            ReservationStatus @default(EN_ATTENTE)
  montant           Float
  commissionMontant Float?
  stripePaymentId   String?
  civilite          String?
  nom               String
  prenom            String
  email             String
  telephone         String
  adresse           String?
  codePostal        String?
  ville             String?
  numeroPermis      String?
  // Cas du stage déclaré par le stagiaire (parmi les 4 cas réglementaires) :
  // 1 = volontaire, 2 = probatoire (48N), 3 = alternative/composition pénale, 4 = peine complémentaire.
  casStage          Int?
  // Attestation d'éligibilité (document de vente — étape avant paiement)
  // Aucune base nationale n'étant accessible, l'éligibilité repose sur une
  // attestation sur l'honneur du stagiaire, conservée comme preuve.
  attestationPasStage12Mois Boolean   @default(false) // n'a pas suivi de stage récup points < 12 mois avant la date de début
  attestationPermisValide   Boolean   @default(false) // permis en cours de validité (même si solde de points nul ou négatif)
  attestationLe             DateTime? // horodatage de l'attestation
  /// @deprecated Remplacés par le modèle `Document` (kind LETTRE_48N / PIECE_IDENTITE,
  /// direction ELEVE_VERS_CENTRE). Plus aucune lecture/écriture dans src/ : conservés
  /// uniquement pour ne pas perdre les URL des réservations antérieures à la migration.
  /// Supprimables via un DROP COLUMN une fois les données legacy vérifiées.
  lettre48NUrl      String?
  pieceIdentiteUrl  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  /// Verrou d'idempotence du pipeline post-paiement (archivage des PDF + emails).
  /// La route /api/reservations ET le webhook Stripe tentent tous deux de le
  /// réclamer via un UPDATE ... WHERE "fulfilledAt" IS NULL : un seul gagne, ce qui
  /// évite le double envoi. Remis à NULL si le pipeline échoue, pour permettre au
  /// filet de sécurité de réessayer. Cf. lib/reservation-fulfillment.ts
  fulfilledAt           DateTime?

  rappelEnvoye          Boolean @default(false)
  questionnaireEnvoye   Boolean @default(false)

  // Relations
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id])
  invoice   Invoice?
  messages  Message[]
  questionnaireResponses QuestionnaireResponse[]
  review                 Review?
  documents              Document[]
  emailLogs              EmailLog[]

  @@map("reservations")
}

// ─── DOCUMENTS ───────────────────────────────────────────

model Document {
  id          String            @id @default(cuid())
  kind        DocumentKind
  direction   DocumentDirection
  nom         String
  description String?
  blobUrl     String? // URL du fichier (Vercel Blob ou /uploads en dev) ; null si bon d'accord texte non encore généré
  contenu     String? // texte (bon d'accord / règlement sans fichier) — sert à générer le PDF probant
  mimeType    String?
  taille      Int? // octets
  status      DocumentStatus @default(ENVOYE)
  // Acceptation à valeur probante (bon d'accord) — action de l'ÉLÈVE
  requiresAck Boolean   @default(false)
  acceptedAt  DateTime?
  acceptedNom String?
  acceptedIp  String?

  // Vérification des justificatifs (permis, CNI, 48N) — action du CENTRE.
  // Distincte de l'acceptation ci-dessus : ici c'est le centre qui contrôle une
  // pièce fournie par l'élève. status passe à ACCEPTE (validé) ou REFUSE.
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?     @relation("VerifiedDocuments", fields: [verifiedById], references: [id])
  motifRefus   String?

  /// Purge RGPD : horodatage de destruction du fichier. La ligne est conservée
  /// (preuve que la pièce a bien été fournie puis détruite) mais `blobUrl` est
  /// vidé. Cf. /api/cron/purge-documents — 45 jours après la fin du stage.
  purgedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  centreId      String?
  centre        Centre?     @relation(fields: [centreId], references: [id])
  uploadedById  String?
  uploadedBy    User?       @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  templateId    String?
  template      CentreDocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([centreId])
  @@index([reservationId, direction])
  @@map("documents")
}

model CentreDocumentTemplate {
  id          String       @id @default(cuid())
  nom         String
  description String?
  blobUrl     String? // fichier joint (ex règlement.pdf)
  contenu     String? // texte inline (bon d'accord sans fichier)
  kind        DocumentKind @default(AUTRE)
  requiresAck Boolean      @default(false) // doit être accepté (bon d'accord)
  autoSend    Boolean      @default(true) // envoyé automatiquement à la confirmation de réservation
  actif       Boolean      @default(true)
  ordre       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  centreId  String
  centre    Centre     @relation(fields: [centreId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([centreId])
  @@map("centre_document_templates")
}

// ─── FACTURES ────────────────────────────────────────────

model Invoice {
  id         String   @id @default(cuid())
  numero     String   @unique // FAC-2026-0001
  type       String // "ELEVE" | "CENTRE_COMMISSION" | "CENTRE_ABONNEMENT"
  montantHT  Float
  tva        Float
  montantTTC Float
  status     String   @default("PAYEE") // "PAYEE" | "EN_ATTENTE" | "ANNULEE"
  pdfUrl     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  centreId      String?
  centre        Centre?      @relation(fields: [centreId], references: [id])
  reservationId String?      @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@map("invoices")
}

// ─── SUPPORT / TICKETS ───────────────────────────────────

model Ticket {
  id        String         @id @default(cuid())
  sujet     String
  status    TicketStatus   @default(OUVERT)
  priorite  TicketPriorite @default(NORMALE)
  categorie String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  userId   String
  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  contenu   String
  fichier   String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@map("ticket_messages")
}

// ─── AVIS / REVIEWS ──────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  note        Int // 1-5 stars (moyenne arrondie du questionnaire)
  notePrecise Float? // moyenne exacte (demi-étoiles)
  commentaire String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id])
  formationId   String
  formation     Formation   @relation(fields: [formationId], references: [id])
  reservationId String?     @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@unique([userId, formationId])
  @@map("reviews")
}

// ─── QUESTIONNAIRES SATISFACTION ─────────────────────────

model QuestionnaireQuestion {
  id        String            @id @default(cuid())
  type      QuestionnaireType
  ordre     Int               @default(0)
  libelle   String
  actif     Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  centreId String?
  centre   Centre? @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@index([centreId, type])
  @@map("questionnaire_questions")
}

model QuestionnaireResponse {
  id          String            @id @default(cuid())
  type        QuestionnaireType
  noteGlobale Float
  reponses    Json // [{ questionId, libelle, note }]
  commentaire String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id])
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  centreId      String?
  centre        Centre?     @relation(fields: [centreId], references: [id])
  formationId   String?
  formation     Formation?  @relation(fields: [formationId], references: [id])

  @@unique([userId, reservationId, type])
  @@index([centreId, type])
  @@map("questionnaire_responses")
}

// ─── FAQ ─────────────────────────────────────────────────

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  reponse   String
  categorie String?
  ordre     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── EMAIL TEMPLATES ─────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String // "convocation", "confirmation_reservation", "rappel_session", "bienvenue", "centre_notification"
  nom       String // "Convocation de stage", etc.
  sujet     String // Email subject with variables like {{prenom}}, {{formation}}
  contenu   String // HTML body with variables
  variables String[] // List of available variables
  isActive  Boolean  @default(true)
  centreId  String? // null = default template, centreId = centre-specific override
  centre    Centre?  @relation(fields: [centreId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, centreId])
  @@map("email_templates")
}

/// Journal des emails sortants. Sert à deux choses :
///   1. Traçabilité (qui a reçu quoi, quand, succès/échec + id Resend).
///   2. Idempotence des envois : le webhook Stripe rejoue le pipeline de
///      fulfillment en filet de sécurité et s'appuie sur ce journal pour ne pas
///      renvoyer un email déjà parti (cf. lib/reservation-fulfillment.ts).
model EmailLog {
  id           String       @id @default(cuid())
  destinataire String
  sujet        String
  /// Identifiant fonctionnel de l'envoi ("confirmation_reservation", "convocation"…)
  kind       String
  status     EmailLogStatus @default(ENVOYE)
  error      String?
  providerId String? // id du message Resend
  createdAt  DateTime       @default(now())

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  centreId      String?
  centre        Centre?      @relation(fields: [centreId], references: [id], onDelete: SetNull)

  @@index([reservationId, kind, status])
  @@index([destinataire])
  @@index([createdAt])
  @@map("email_logs")
}

enum EmailLogStatus {
  ENVOYE
  ECHEC
}

// ─── PAIEMENTS CENTRES ──────────────────────────────────

model CentrePayment {
  id          String   @id @default(cuid())
  type        String // "COMMISSION" | "ABONNEMENT" | "REMBOURSEMENT"
  montant     Float
  description String
  stripeId    String? // Stripe payment/invoice ID
  status      String   @default("EN_ATTENTE") // "EN_ATTENTE" | "PAYE" | "ECHOUE"
  periode     String? // "2026-03" for monthly tracking
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  centreId String
  centre   Centre @relation(fields: [centreId], references: [id])

  @@map("centre_payments")
}

// ─── CODES PROMO ─────────────────────────────────────────

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  type            String // "POURCENTAGE" | "MONTANT_FIXE"
  valeur          Float // 10 = 10% or 10€
  minAchat        Float? // Minimum purchase amount
  maxUtilisations Int? // Max total uses (null = unlimited)
  utilisations    Int      @default(0)
  dateDebut       DateTime
  dateFin         DateTime
  isActive        Boolean  @default(true)
  centreId        String? // null = platform-wide, centreId = centre-specific
  centre          Centre?  @relation(fields: [centreId], references: [id])
  createdAt       DateTime @default(now())

  @@map("promo_codes")
}

// ─── PARAMETRES PLATEFORME ───────────────────────────────

model PlatformSettings {
  id                 String            @id @default("default")
  commissionRate     Float             @default(10)
  monetisationModel  MonetisationModel @default(COMMISSION)
  maintenanceMode    Boolean           @default(false)
  maintenanceMessage String?
  updatedAt          DateTime          @updatedAt

  @@map("platform_settings")
}

// ─── ARTICLES / BLOG ────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  titre       String
  slug        String    @unique
  extrait     String // Short excerpt for cards
  contenu     String // Full HTML content
  image       String? // Cover image URL
  categorie   String? // "actualites" | "conseils" | "reglementation" | "partenaires"
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("articles")
}

// ─── MESSAGERIE CENTRE-ELEVE ────────────────────────────

model Message {
  id        String   @id @default(cuid())
  contenu   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId   String
  sender     User   @relation("messagesSent", fields: [senderId], references: [id])
  receiverId String
  receiver   User   @relation("messagesReceived", fields: [receiverId], references: [id])

  // Context
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  @@map("messages")
}

// ─── PROGRAMME DE FIDÉLITÉ ──────────────────────────────

model LoyaltyPoints {
  id          String   @id @default(cuid())
  points      Int
  type        String // "GAIN" | "DEPENSE"
  description String
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_points")
}

// ─── FAVORIS / WISHLIST ─────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  formationId String
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([userId, formationId])
  @@map("favorites")
}

// ─── IDEMPOTENCE WEBHOOKS (Stripe, Auth0, etc.) ─────────

/**
 * Track processed webhook events to ensure idempotence.
 * Stripe (and other providers) may deliver the same event multiple times.
 * Inserting on each event with a unique constraint on id+provider prevents
 * double-processing (e.g. double commission, duplicate reservations).
 */
model WebhookEvent {
  id          String   @id // Event id from provider (e.g. Stripe evt_xxx)
  provider    String // "stripe" | "auth0" | ...
  type        String // Event type (e.g. payment_intent.succeeded)
  processedAt DateTime @default(now())

  @@unique([provider, id])
  @@map("webhook_events")
}

// ─── DISPONIBILITES FORMATEUR ──────────────────────────

model Availability {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String // "09:00"
  endTime   String // "17:00"
  isBooked  Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}
